{
  "name": "api-response-kit",
  "version": "1.0.0",
  "description": "Standardize your Node.js API responses with a consistent format",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ adapters/ --ext .ts",
    "lint:fix": "eslint src/ adapters/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"adapters/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "api",
    "response",
    "express",
    "nestjs",
    "fastify",
    "rest",
    "standardize",
    "typescript"
  ],
  "author": "Kamran534",
  "license": "MIT",
  "files": [
    "dist",
    "adapters"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kamran534/DevOps.git"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "express": "^4.18.2",
    "fastify": "^4.25.0",
    "fastify-plugin": "^4.5.1",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  }
}
